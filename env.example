# === ОБЯЗАТЕЛЬНЫЕ ===

# Токен от BotFather (см. инструкцию ниже)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# API ключ Anthropic — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxxxx

# === ОПЦИОНАЛЬНЫЕ ===

# Кому разрешён доступ (telegram username без @, через запятую). Пусто = все
ALLOWED_USERS=dtonkopiy

# Модель Claude
CLAUDE_MODEL=claude-sonnet-4-20250514

# Макс. сообщений в истории диалога
MAX_HISTORY=50
